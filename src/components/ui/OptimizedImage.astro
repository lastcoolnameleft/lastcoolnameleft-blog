---
import { isCloudinaryUrl, lqip } from "../../utils/cloudinary";
import { cn } from "../../utils/styles";
import { url } from "../../utils/url-utils";
import { CldImage, type CldImageProps } from "astro-cloudinary";

interface Props extends CldImageProps {
    wrapperClass?: string;
    imageClass?: string;
}

const {
    src,
    alt,
    wrapperClass = "",
    imageClass = "",
    loading = "lazy",
    fetchpriority,
    ...rest
} = Astro.props;

const fetchPriorityVal =
    loading === "eager" ? (fetchpriority ?? "high") : undefined;

const useCloudinaryImage = isCloudinaryUrl(src);
const isPublic = src.startsWith("/");
const resolvedSrc = isPublic ? url(src) : src;
const lqipUrl = useCloudinaryImage ? lqip(src) : undefined;
---

<div
    class={cn(
        "relative overflow-hidden bg-neutral-200 dark:bg-neutral-700",
        wrapperClass,
    )}
>
    {
        lqipUrl && (
            <img
                data-pagefind-ignore
                src={lqipUrl}
                alt=""
                aria-hidden="true"
                class={cn(
                    "absolute inset-0 h-full w-full scale-105 object-cover blur-xl",
                    imageClass,
                )}
                loading="eager"
                decoding="async"
            />
        )
    }

    {
        useCloudinaryImage ? (
            <CldImage
                src={src}
                alt={alt}
                class={cn("absolute inset-0 h-full w-full object-cover", imageClass)}
                loading={loading}
                fetchpriority={fetchPriorityVal}
                format="auto"
                quality="auto"
                {...rest}
            />
        ) : (
            <img
                src={resolvedSrc}
                alt={alt}
                class={cn("absolute inset-0 h-full w-full object-cover", imageClass)}
                loading={loading}
                fetchpriority={fetchPriorityVal}
                decoding="async"
            />
        )
    }
</div>
