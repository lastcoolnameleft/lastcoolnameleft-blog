---
import { type LinkVariants, link } from "./link";
import { cn } from "../../../utils/styles";
import type { HTMLAttributes } from "astro/types";
import { url } from "../../../utils/url-utils";

interface Props extends HTMLAttributes<"a">, LinkVariants {}

const { href, class: cls, target, rel, variant, ...rest } = Astro.props;

const isExternal =
    href instanceof URL ||
    (typeof href === "string" &&
        (href.startsWith("http://") || href.startsWith("https://")));

const resolvedHref =
    typeof href === "string" && href.startsWith("/")
        ? url(href)
        : href;

const computedTarget = target ?? (isExternal ? "_blank" : undefined);
const computedRel = rel ?? (isExternal ? "noopener noreferrer" : undefined);
---

<a
    href={resolvedHref}
    target={computedTarget}
    rel={computedRel}
    class={cn(link({ variant }), cls)}
    {...rest}
>
    <slot />
</a>
