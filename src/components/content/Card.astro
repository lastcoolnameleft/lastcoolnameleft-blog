---
import OptimizedImage from "../ui/OptimizedImage.astro";
import type { ContentEntry, ImageLoading, WithMeta } from "../../types";
import FeaturedTag from "./FeaturedTag.astro";
import FormattedDate from "./FormattedDate.astro";
import Series from "./Series.astro";
import Tags from "./Tags.astro";
import { url } from "../../utils/url-utils";

interface Props {
    entry: WithMeta<ContentEntry>;
    loading?: ImageLoading;
}
const { entry, loading = "lazy" } = Astro.props;

const { collection, id, data, meta } = entry;
const {
    title,
    description,
    pubDate,
    updatedDate,
    image,
    featured,
    series,
    tags,
} = data;
const { readingTimeText } = meta || {};
const cardImage = image ?? meta?.previewImage;
const hasImage = Boolean(cardImage);
const noImageTeaser = meta?.plainText?.trim() || description;

const displayDate = updatedDate ?? pubDate;
---

<article class="group relative flex h-full flex-col rounded-xl border border-[var(--surface-border)] bg-[var(--surface-muted)] p-3 shadow-[0_10px_24px_-20px_rgba(0,0,0,0.5)]">
    {featured && <FeaturedTag class="absolute top-1 left-1 z-10" />}

    {cardImage && (
        <OptimizedImage
            src={cardImage.src}
            alt={cardImage.alt ?? title}
            width={1600}
            height={900}
            sizes="(max-width: 768px) 100vw, 33vw"
            loading={loading}
            wrapperClass="mb-4 aspect-video rounded-lg"
            imageClass="transition duration-250 ease-out group-hover:scale-105 group-active:scale-105"
        />
    )}

    <h3
        class:list={[
            "mb-2 text-xl font-semibold transition-colors duration-250 ease-out group-hover:text-[var(--accent)] group-active:text-[var(--accent)]",
            hasImage && "line-clamp-2",
        ]}
    >
        <a
            href={url(`/${collection}/${id}`)}
            class="after:absolute after:inset-0 after:content-['']"
        >
            {title}
        </a>
    </h3>
    {
        hasImage ? (
            <p class="line-clamp-3 text-[var(--text-muted)]">{description}</p>
        ) : (
            <p class="line-clamp-10 text-[var(--text-muted)]">{noImageTeaser}</p>
        )
    }

    <div class="mt-3.5 flex flex-col items-start gap-y-4">
        {series && <Series {series} class="relative z-10" />}
        {tags.length > 0 && <Tags {tags} class="relative z-10" />}

        <div
            class="flex items-center gap-x-2 text-sm text-[var(--text-muted)]"
        >
            <FormattedDate date={displayDate} />
            {
                readingTimeText && (
                    <>
                        <span>&middot;</span>
                        <span>{readingTimeText}</span>
                    </>
                )
            }
        </div>
    </div>
</article>
