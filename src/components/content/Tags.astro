---
import { cn } from "../../utils/styles";

interface Props {
    tags: string[];
    class?: string;
}

const { tags, class: cls = "" } = Astro.props;
---

<div class={cn("flex flex-wrap gap-2", cls)}>
    {
        tags.map((tag) => (
            // href={`/search?tags=${encodeURIComponent(tag)}`}
            <span class="rounded-md border border-[var(--surface-border)] bg-[var(--surface)] px-2 py-1 text-sm text-[var(--text-main)]">
                {tag}
            </span>
        ))
    }
</div>
