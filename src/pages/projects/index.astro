---
import { getCollection } from "astro:content";
import ListLayout from "../../layouts/ListLayout.astro";
import { attachMeta } from "../../utils/meta";

const PROJECT_IDS = new Set([
    "2025/2025-lewisville-punkin-chunkin",
    "2025/disco-kilt-a-journey-of-sparkles-leds-and-scottish-pride",
    "2019/roboclippy-combining-20-years-of-internet-rage-into-an-adorable-package",
    "2020/how-i-built-a-super-cool-led-lanyard",
]);

const projects = (await getCollection("blog", ({ data, id }) =>
    !data.draft && PROJECT_IDS.has(id)
))
    .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
    .map((p) => attachMeta(p));
---

<ListLayout
    title="Projects"
    description="A collection of my projects."
    entries={projects}
/>
